{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "sourceMap": true,
    "noEmit": true,
    "jsx": "preserve",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/env.d.ts",
    "src/App.vue",
    "src/main.ts",
    "src/api/client.ts",
    "src/api/auth.ts",
    "src/api/article.ts",
    "src/api/menu.ts",
    "src/api/upload.ts",
    "src/api/system.ts",
    "src/components/article/rich-text-editor.vue",
    "src/layout/index.vue",
    "src/router/index.ts",
    "src/store/index.ts",
    "src/store/modules/session.ts",
    "src/views/login/login.vue",
    "src/views/home/home.vue",
    "src/views/biz/articles/index.vue",
    "src/views/biz/articles/form.vue",
    "src/views/biz/menus/index.vue",
    "src/views/biz/uploads/index.vue",
    "src/views/biz/system/admin-menus.vue",
    "src/views/biz/system/admins.vue",
    "src/views/biz/system/apis.vue",
    "src/views/biz/system/configs.vue",
    "src/views/biz/system/dicts.vue",
    "src/views/biz/system/depts.vue",
    "src/views/biz/system/jobs.vue",
    "src/views/biz/system/login-logs.vue",
    "src/views/biz/system/online-users.vue",
    "src/views/biz/system/operation-logs.vue",
    "src/views/biz/system/posts.vue",
    "src/views/biz/system/roles.vue",
    "src/views/biz/modules/index.vue",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
